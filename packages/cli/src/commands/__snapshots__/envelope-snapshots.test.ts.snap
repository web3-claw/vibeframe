    "type": "object",
  },
}
`;

exports[`CLI --describe schemas (drift detection) > vibe generate video --describe 1`] = `
{
  "description": "Generate video using AI (Seedance, Grok, Kling, Runway, or Veo)",
  "name": "generate.video",
  "parameters": {
    "properties": {
      "apiKey": {
        "description": "API key (or set FAL_KEY / XAI_API_KEY / RUNWAY_API_SECRET / KLING_API_KEY / GOOGLE_API_KEY env)",
        "type": "string",
      },
      "dryRun": {
        "description": "Preview parameters without executing",
        "type": "boolean",
      },
      "duration": {
        "default": 5,
        "description": "Duration in seconds. Seedance accepts 4-15 (\`fal\` alias supported); Kling accepts 5 or 10; Veo maps to 6 or 8.",
        "type": "number",
      },
      "image": {
        "description": "Reference image for image-to-video",
        "type": "string",
      },
      "lastFrame": {
        "description": "Last frame image for frame interpolation (Veo only)",
        "type": "string",
      },
      "mode": {
        "default": "std",
        "description": "Generation mode: std or pro (Kling only)",
        "type": "string",
      },
      "negative": {
        "description": "Negative prompt - what to avoid (Kling/Veo)",
        "type": "string",
      },
      "noWait": {
        "description": "Start generation and return task ID without waiting",
        "type": "boolean",
      },
      "output": {
        "description": "Output file path (downloads video)",
        "type": "string",
      },
      "person": {
        "description": "Person generation: allow_all, allow_adult (Veo only)",
        "type": "string",
      },
      "prompt": {
        "description": "Text prompt describing the video (interactive if omitted)",
        "type": "string",
      },
      "provider": {
        "description": "Provider: seedance (ByteDance Seedance 2.0 via fal.ai), grok, kling, runway, veo. \`fal\` is a backwards-compatible alias for seedance.",
        "type": "string",
      },
      "ratio": {
        "description": "Aspect ratio: 16:9, 9:16, or 1:1 (auto-detected from image if omitted)",
        "enum": [
          "16:9",
          "9:16",
          "1:1",
        ],
        "type": "string",
      },
      "refImages": {
        "description": "Reference images for character consistency (Veo 3.1 only, max 3)",
        "type": "string",
      },
      "resolution": {
        "description": "Video resolution: 720p, 1080p, 4k (Veo only)",
        "enum": [
          "720p",
          "1080p",
          "4k",
        ],
        "type": "string",
      },
      "runwayModel": {
        "default": "gen4.5",
        "description": "Runway model: gen4.5 (default, text+image-to-video), gen4_turbo (image-to-video only)",
        "type": "string",
      },
      "seed": {
        "description": "Random seed for reproducibility (Runway only)",
        "type": "number",
      },
      "seedanceModel": {
        "default": "quality",
        "description": "Seedance variant: quality or fast (fal.ai only)",
        "type": "string",
      },
      "veoModel": {
        "default": "3.1-fast",
        "description": "Veo model: 3.0, 3.1, 3.1-fast (default: 3.1-fast)",
        "type": "string",
      },
    },
    "type": "object",
  },
}
`;

