        "default": 10,
        "description": "Maximum turns per request",
        "type": "number",
      },
      "model": {
        "description": "Model to use (provider-specific)",
        "type": "string",
      },
      "project": {
        "description": "Timeline file or directory to load",
        "type": "string",
      },
      "provider": {
        "default": "openai",
        "description": "LLM provider (openai, claude, gemini, ollama, xai, openrouter)",
        "enum": [
          "openai",
          "claude",
          "gemini",
          "ollama",
          "xai",
          "openrouter",
        ],
        "type": "string",
      },
      "verbose": {
        "description": "Show verbose output including tool calls",
        "type": "boolean",
      },
    },
    "type": "object",
  },
}
`;

