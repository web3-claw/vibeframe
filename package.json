{
  "name": "vibeframe",
  "version": "0.79.1",
  "description": "AI-native video editing tool. CLI-first, MCP-ready.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vericontext/vibeframe.git"
  },
  "homepage": "https://vibeframe.dev",
  "bugs": {
    "url": "https://github.com/vericontext/vibeframe/issues"
  },
  "keywords": [
    "vibeframe",
    "video-editing",
    "ai",
    "cli",
    "mcp",
    "ffmpeg",
    "remotion"
  ],
  "author": "VibeFrame Contributors",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "vibe": "tsx packages/cli/src/index.ts",
    "mcp": "tsx packages/mcp-server/src/index.ts",
    "scaffold:provider": "tsx scripts/scaffold-provider.mts",
    "scaffold:command": "tsx scripts/scaffold-command.mts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "packageExtensions": {
      "@hyperframes/engine": {
        "types": "./dist/index.d.ts",
        "exports": {
          ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
          }
        }
      }
    }
  }
}
